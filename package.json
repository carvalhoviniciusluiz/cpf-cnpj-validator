{
  "name": "cpf-cnpj-validator",
  "version": "1.1.0",
  "description": "Valida, formata e gera strings de CPF ou CNPJ, com suporte ao novo formato alfanumérico da RFB e adapters para joi, yup e zod.",
  "author": "Carvalho, Vinicius Luiz <carvalho.viniciusluiz@gmail.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./joi": {
      "types": "./dist/joi.d.ts",
      "import": "./dist/joi.js",
      "require": "./dist/joi.cjs"
    },
    "./yup": {
      "types": "./dist/yup.d.ts",
      "import": "./dist/yup.js",
      "require": "./dist/yup.cjs"
    },
    "./zod": {
      "types": "./dist/zod.d.ts",
      "import": "./dist/zod.js",
      "require": "./dist/zod.cjs"
    },
    "./class-validator": {
      "types": "./dist/class-validator.d.ts",
      "import": "./dist/class-validator.js",
      "require": "./dist/class-validator.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "class-validator": "^0.14.0 || ^0.15.0",
    "joi": "^17.0.0",
    "reflect-metadata": "^0.2.0",
    "yup": "^1.0.0",
    "zod": "^3.22.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "class-validator": {
      "optional": true
    },
    "joi": {
      "optional": true
    },
    "reflect-metadata": {
      "optional": true
    },
    "yup": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "class-validator": "^0.15.1",
    "joi": "^17.13.3",
    "reflect-metadata": "^0.2.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4",
    "yup": "^1.7.1",
    "zod": "^4.3.6"
  },
  "keywords": [
    "node",
    "joi",
    "yup",
    "zod",
    "cpf",
    "cnpj",
    "validator",
    "alfanumerico",
    "receita-federal",
    "class-validator",
    "nestjs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carvalhoviniciusluiz/cpf-cnpj-validator.git"
  },
  "bugs": {
    "url": "https://github.com/carvalhoviniciusluiz/cpf-cnpj-validator/issues"
  },
  "homepage": "https://github.com/carvalhoviniciusluiz/cpf-cnpj-validator#readme"
}
